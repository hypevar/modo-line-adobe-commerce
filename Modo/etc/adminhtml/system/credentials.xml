<include xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_include.xsd">
    <group id="production_credentials" translate="label" showInWebsite="1" showInStore="1"
           showInDefault="1">
        <label>Credentials</label>
        <depends>
            <field id="*/*/active">1</field>
            <field id="*/*/environment">production</field>
        </depends>
        <field id="pub_key" type="obscure" showInWebsite="1" showInStore="1" showInDefault="1"
               translate="label">
            <label>Public Key</label>
            <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
        </field>
        <field id="secret_key" type="obscure" showInWebsite="1" showInStore="1" showInDefault="1"
               translate="label">
            <label>Secret Key</label>
            <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
        </field>
    </group>
    <group id="sandbox_credentials" translate="label" showInWebsite="1" showInStore="1"
           showInDefault="1">
        <label>Credentials</label>
        <depends>
            <field id="*/*/active">1</field>
            <field id="*/*/environment">sandbox</field>
        </depends>
        <field id="pub_key" type="obscure" showInWebsite="1" showInStore="1" showInDefault="1"
               translate="label">
            <label>Public Key</label>
            <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
        </field>
        <field id="secret_key" type="obscure" showInWebsite="1" showInStore="1" showInDefault="1"
               translate="label">
            <label>Secret Key</label>
            <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
        </field>
    </group>
</include>
