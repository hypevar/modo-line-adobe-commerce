<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <preference for="Line\Promotions\Api\ConfigInterface" type="Line\Promotions\Model\Config"/>

    <!-- Custom log file (/var/log/line_promotions.log) -->
    <virtualType name="Line\Promotions\Logger\Handler"
                 type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">/var/log/line_promotions.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="LinePromotionsLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="info" xsi:type="object">Line\Promotions\Logger\Handler</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Line\Promotions\Model\Api\ApiClient">
        <arguments>
            <argument name="logger" xsi:type="object">LinePromotionsLogger</argument>
        </arguments>
    </type>
    <type name="Line\Promotions\Model\CcCodeResolver">
        <arguments>
            <argument name="logger" xsi:type="object">LinePromotionsLogger</argument>
        </arguments>
    </type>

</config>
